# Copier vers `.env.prod` sur le VPS : /var/www/html/habitracks/.env.prod
# Ne jamais committer `.env.prod` avec des vrais secrets.

# ── Postgres (service `db` dans docker-compose.prod.yml) ─────────────────────
POSTGRES_DB=habittracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=remplacer_par_mot_de_passe_fort

# URL vue par le backend dans le réseau Docker (hostname = nom du service `db`)
DATABASE_URL=postgresql://postgres:remplacer_par_mot_de_passe_fort@db:5432/habittracker

# ── Auth / app ────────────────────────────────────────────────────────────────
JWT_SECRET=minimum_16_caracteres_aleatoires_en_prod
JWT_EXPIRES_IN=7d
NODE_ENV=production

# URL publique du site (Apache / TLS) — CORS + cookies
FRONTEND_URL=https://habitracks.vitalinfo.site

# Inscriptions libres POST /auth/register : false recommandé en prod sauf besoin
 REGISTER_OPEN=true

# ── Rate limiting ─────────────────────────────────────────────────────────────
API_RATE_WINDOW_MS=900000
API_RATE_MAX=100
AUTH_RATE_MAX=30

# Déjà forcé à 1 dans docker-compose.prod.yml ; tu peux aussi le laisser ici pour clarté
# TRUST_PROXY=1

# ── Rappels RDV par e-mail (Gmail — mêmes clés que zerok-billing si tu réutilises le compte) ──
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
# APPOINTMENT_REMINDER_DAY_BEFORE_HOUR=18

# ── Web Push (notifications) — npx web-push generate-vapid-keys ─────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@tondomaine.fr

# ── Port hôte → conteneur 3000 (Apache ProxyPass vers 127.0.0.1:CE_PORT) ───────
HOST_PORT_BACKEND=3008
