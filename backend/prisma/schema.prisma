generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── USERS ──────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String?  @unique   // optionnel pour les comptes créés par un éducateur
  username       String   @unique
  passwordHash   String?            // null tant que le compte n'est pas activé
  avatar         String   @default("🦊")
  isPending      Boolean  @default(false)  // true = créé par éducateur, pas encore activé
  activationCode String?  @unique          // code 6 chars, null après activation
  // Compte opérateur (hors parcours élève / éducateur dans l’app)
  isAdmin        Boolean  @default(false)
  isSuspended    Boolean  @default(false) // blocage connexion + API (hors déconnexion)
  lastLoginAt    DateTime? // dernière session (login / register / activation)
  /// Fuseau IANA pour rappels (ex. Europe/Paris)
  ianaTimezone                 String  @default("Europe/Paris")
  /// Heure locale du rappel habitudes (0–23) ; null = défaut global admin
  pushReminderHour             Int?
  pushNotificationsEnabled     Boolean @default(false)
  /// Dernier jour (YMD local) où un rappel habitudes a été envoyé (anti-doublon)
  lastPushReminderSentYmd      String?

  /// Monnaie virtuelle « cristaux »
  cristaux                        Int     @default(0)
  /// Dernier jour civil local où un cristal « connexion » a été attribué (anti-doublon)
  lastCristalConnexionYmd         String?
  /// Dernier jour civil local où le bonus « journée parfaite » a été attribué
  lastCristalJourneeParfaiteYmd   String?

  /// Dernier streak connu après GET /stats/profile (comparaison bannière)
  lastProfileStreakInt Int @default(0)
  /// Dernier jour civil où une bannière streak a été renvoyée (anti-répétition)
  lastStreakBannerYmd  String? @db.VarChar(10)
  /// Dernier jour « clientToday » (YMD) où un sauvetage streak a été payé (anti double débit)
  lastStreakRecoverAnchorYmd String? @db.VarChar(10)
  /// Jokers « sauvetage de série » en stock (achetés en boutique, consommés au recover)
  jokerStreak                  Int     @default(0)

  /// E-mails lorsqu’un pair réagit à une perf d’habitude (❤️ / 🤔)
  perfReactionEmailsEnabled Boolean @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  habits      Habit[]
  habitPerfReactionsFrom HabitPerfReaction[] @relation("HabitPerfReactionFrom")
  habitLogs   HabitLog[]
  dailyLogs   DailyLog[]
  memberships GroupMember[]

  dailyHabitOffers DailyHabitOffer[]

  /// Première ouverture app par jour civil local (YMD) — streak « flamme »
  dailyVisits DailyVisit[]

  appointmentsAssigned     Appointment[]           @relation("AppointmentAssignee")
  appointmentsCreated      Appointment[]           @relation("AppointmentCreator")
  appointmentCompletions   AppointmentCompletion[]

  pushSubscriptions PushSubscription[]
}

/// Clé-valeur (réglages globaux admin, ex. heure de rappel par défaut)
model AppSetting {
  key   String @id
  value String
}

/// Abonnements Web Push (navigateur)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Phrases « message du jour » (Home) — éditables depuis le back-office admin
model MotivationalPhrase {
  id        String   @id @default(cuid())
  category  String   // encouragement | maintien | felicitation
  text      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([category, sortOrder])
}

// Actions admin (support / conformité) — pas de FK pour conserver l’historique si un user est supprimé
model AdminAuditLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  targetId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ── GROUPS ─────────────────────────────────────────────────────────────────────

enum GroupType {
  FRIENDS     // groupe libre entre pairs
  ASSOCIATION // géré par un éducateur
}

enum GroupRole {
  OWNER  // créateur / éducateur
  MEMBER // participant
}

model Group {
  id         String    @id @default(cuid())
  name       String
  type       GroupType @default(FRIENDS)
  inviteCode String    @unique @default(cuid())
  createdAt  DateTime  @default(now())

  members      GroupMember[]
  appointments Appointment[]
}

model GroupMember {
  userId   String
  groupId  String
  role     GroupRole @default(MEMBER)
  // Membre ASSO : consentement pour partager humeur, phrase mémorable, journal avec l’éducateur.
  shareSensitiveCheckinWithOwner Boolean @default(false)
  joinedAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
}

// ── HABITS ─────────────────────────────────────────────────────────────────────

enum HabitOrigin {
  DEFAULT // ex. pack seed à la création du compte (même droits qu’USER après coup)
  USER    // créée par l’utilisateur
  DAILY_OFFER // proposée par l’admin (pools « habitude du jour »)
}

// Modèles proposés comme « habitude du jour » (éditables admin)
model DailyHabitTemplate {
  id        String   @id @default(cuid())
  title     String
  icon      String
  /// XP total attribuée (ex. 10 base + 5 bonus = 15)
  xpTotal   Int      @default(15)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  offers DailyHabitOffer[]
}

enum DailyOfferStatus {
  PENDING
  DISMISSED
  ACCEPTED
}

/// Une ligne par utilisateur et par jour civil — proposition unique / jour
model DailyHabitOffer {
  id         String           @id @default(cuid())
  userId     String
  offerDate  DateTime         @db.Date
  templateId String
  status     DailyOfferStatus @default(PENDING)
  habitId    String?          @unique
  /// Cristal offre du jour déjà crédité (anti-doublon)
  cristauxGranted Boolean @default(false)

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  template DailyHabitTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  habit    Habit?             @relation(fields: [habitId], references: [id], onDelete: SetNull)

  @@unique([userId, offerDate])
  @@index([userId, offerDate])
  @@index([templateId])
}

/// Une ligne par utilisateur et par jour civil (première connexion du jour)
model DailyVisit {
  id     String @id @default(cuid())
  userId String
  /// YYYY-MM-DD (aligné clientToday)
  ymd    String @db.VarChar(10)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ymd])
  @@index([userId, ymd])
}

model Habit {
  id        String      @id @default(cuid())
  userId    String
  name      String
  icon      String
  xp        Int         @default(20)
  order     Int         @default(0)
  origin    HabitOrigin @default(DEFAULT)
  isActive  Boolean     @default(true)
  /// Bits 0–6 = lun→dim ; 127 = tous les jours
  weekdaysMask Int      @default(127)
  createdAt DateTime    @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs              HabitLog[]
  dailyOfferCreated DailyHabitOffer?
  habitPerfReactions HabitPerfReaction[]

  @@index([userId])
}

/// Réaction d’un joueur sur la perf (habitude cochée) d’un autre pour un jour civil (YMD du joueur cible).
enum HabitPerfReactionKind {
  HEART
  SKEPTIC
}

model HabitPerfReaction {
  id         String                @id @default(cuid())
  fromUserId String
  habitId    String
  ymd        String                @db.VarChar(10)
  kind       HabitPerfReactionKind
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  fromUser User  @relation("HabitPerfReactionFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  habit    Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, habitId, ymd])
  @@index([habitId, ymd])
}

model HabitLog {
  id       String   @id @default(cuid())
  habitId  String
  userId   String
  date     DateTime @db.Date
  proofUrl String?

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId])
}

// ── DAILY LOG ──────────────────────────────────────────────────────────────────
// Check-in + sommeil + journal regroupés — 1 entrée par user par jour

model DailyLog {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @db.Date
  mood         Int?
  moodReason   String?
  sleepQuality Int?
  journal      String?
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ── RENDEZ-VOUS (agenda) — assignés à un user ; l’éducateur peut en créer pour un membre ASSO
model Appointment {
  id              String   @id @default(cuid())
  userId          String
  createdByUserId String
  groupId         String?
  title           String
  notes           String?
  date            DateTime @db.Date
  // Heure du RDV (24h), ex. "09:30"
  timeHm          String   @default("09:00") @db.VarChar(5)
  xpReward        Int      @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  /// E-mail « la veille » déjà envoyé (anti-doublon)
  emailReminderDayBeforeSentAt   DateTime?
  /// E-mail « 1 h avant » déjà envoyé (anti-doublon)
  emailReminderHourBeforeSentAt  DateTime?

  assignee    User @relation("AppointmentAssignee", fields: [userId], references: [id], onDelete: Cascade)
  createdBy   User @relation("AppointmentCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  group       Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  completions AppointmentCompletion[]

  @@index([userId, date])
  @@index([createdByUserId])
  @@index([groupId])
}

model AppointmentCompletion {
  id              String   @id @default(cuid())
  appointmentId   String
  userId          String
  date            DateTime @db.Date
  xpEarned        Int
  createdAt       DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, date])
  @@index([userId, date])
}
