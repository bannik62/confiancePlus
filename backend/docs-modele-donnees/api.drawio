<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram id="api-overview" name="Frontend-API (aperçu)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1"
      connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240"
      pageHeight="920" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="note" value="Vue d’ensemble — préfixes réels (`app.js`, `*router.js`). Flèches = usages principaux ; détail des query/body dans le code."
          style="text;html=1;strokeColor=none;fillColor=#fff4e6;align=left;verticalAlign=middle;fontSize=11;spacing=8;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1080" height="44" as="geometry"/>
        </mxCell>

        <!-- Frontend -->
        <mxCell id="frontend" value="Frontend (Svelte PWA)"
          style="swimlane;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="280" height="400" as="geometry"/>
        </mxCell>

        <mxCell id="login" value="Login.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="40" width="240" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="home" value="Home.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="86" width="240" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="checkin_view" value="CheckIn.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="132" width="240" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="group" value="Groupe.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="178" width="240" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="stats" value="Stats.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="224" width="240" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="profil" value="Profil.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="270" width="240" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="admin_fe" value="Admin.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="316" width="240" height="36" as="geometry"/>
        </mxCell>

        <!-- Backend -->
        <mxCell id="backend" value="Backend API (Express) — /api/*"
          style="swimlane;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="420" height="800" as="geometry"/>
        </mxCell>

        <mxCell id="auth" value="/api/auth&#xa;- POST /login (+ loginMode, inviteCode → matchedGroupId)&#xa;- POST /register · POST /logout · GET /me&#xa;- POST /check-code · POST /activate"
          style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=6;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="40" width="380" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="habits" value="/api/habits (CSRF)&#xa;- GET /?date=…&#xa;- POST / · PATCH /:id · DELETE /:id&#xa;- PATCH /:id/toggle"
          style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=6;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="155" width="380" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="checkin" value="/api/checkin (CSRF)&#xa;- GET /today · POST /"
          style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=6;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="260" width="380" height="64" as="geometry"/>
        </mxCell>

        <mxCell id="group_api" value="/api/group (CSRF)&#xa;- GET / · POST / · POST /join&#xa;- GET /:id/leaderboard · POST /:id/members&#xa;- PATCH /:id/membership/sensitive-sharing"
          style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=6;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="339" width="380" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="stats_api" value="/api/stats (GET)&#xa;- GET /me (?clientToday) · GET /profile&#xa;- GET /leaderboard · GET /educator-overview&#xa;- GET /calendar/:year · GET /insights"
          style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=6;fillColor=#e1d5e7;strokeColor=#9673a6;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="454" width="380" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="educator_api" value="/api/educator (CSRF)&#xa;- GET /groups/:groupId/members/:memberId/overview&#xa;  (?year, habitsDate, clientToday)"
          style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=6;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="569" width="380" height="72" as="geometry"/>
        </mxCell>

        <mxCell id="content_api" value="/api/content&#xa;- GET /day-messages (public)"
          style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=6;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="656" width="380" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="admin_api" value="/api/admin (CSRF + requireAdmin)&#xa;- GET/DELETE/PATCH users… · GET /audit · GET /groups&#xa;- GET/PUT /day-messages"
          style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=6;fillColor=#f8cecc;strokeColor=#b85450;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="725" width="380" height="72" as="geometry"/>
        </mxCell>

        <!-- Database -->
        <mxCell id="db" value="PostgreSQL&#xa;(Prisma)&#xa;User · Group · GroupMember&#xa;Habit · HabitLog · DailyLog&#xa;+ tables admin / phrases…"
          style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#fff2cc;strokeColor=#d6b656;"
          vertex="1" parent="1">
          <mxGeometry x="900" y="320" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell id="e1" style="endArrow=block;html=1;" edge="1" parent="1" source="login" target="auth">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;" edge="1" parent="1" source="home" target="habits">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=block;html=1;" edge="1" parent="1" source="home" target="checkin">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3b" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="home" target="group_api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="endArrow=block;html=1;" edge="1" parent="1" source="group" target="group_api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="endArrow=block;html=1;" edge="1" parent="1" source="stats" target="stats_api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5b" style="endArrow=block;html=1;" edge="1" parent="1" source="profil" target="stats_api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ck" style="endArrow=block;html=1;" edge="1" parent="1" source="checkin_view" target="checkin">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ad" style="endArrow=block;html=1;" edge="1" parent="1" source="admin_fe" target="admin_api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="endArrow=block;html=1;" edge="1" parent="1" source="backend" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
