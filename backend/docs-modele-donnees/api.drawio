<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Frontend-Backend Routes">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1"
      connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100"
      pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Frontend -->
        <mxCell id="frontend" value="Frontend (Svelte PWA)"
          style="swimlane;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="260" height="420" as="geometry"/>
        </mxCell>

        <mxCell id="login" value="Login.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="40" width="220" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="home" value="Home.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="100" width="220" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="group" value="Groupe.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="160" width="220" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="stats" value="Stats.svelte"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="frontend">
          <mxGeometry x="20" y="220" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- Backend -->
        <mxCell id="backend" value="Backend API (Express)"
          style="swimlane;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="420" y="80" width="320" height="520" as="geometry"/>
        </mxCell>

        <mxCell id="auth" value="/api/auth&#xa;- POST /login&#xa;- POST /register&#xa;- POST /logout&#xa;- GET /me&#xa;- POST /check-code&#xa;- POST /activate"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="40" width="280" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="habits" value="/api/habits&#xa;- GET /&#xa;- POST /&#xa;- PATCH /:id/toggle&#xa;- PATCH /:id&#xa;- DELETE /:id"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="180" width="280" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="checkin" value="/api/checkin&#xa;- GET /today&#xa;- POST /"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="320" width="280" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="group_api" value="/api/group&#xa;- GET /my&#xa;- POST /&#xa;- POST /join&#xa;- POST /:id/members&#xa;- GET /:id/leaderboard"
          style="rounded=1;whiteSpace=wrap;html=1;"
          vertex="1" parent="backend">
          <mxGeometry x="20" y="420" width="280" height="120" as="geometry"/>
        </mxCell>

        <!-- Database -->
        <mxCell id="db" value="PostgreSQL&#xa;User | Group | GroupMember | Habit | HabitLog | DailyLog"
          style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#fff2cc;strokeColor=#d6b656;"
          vertex="1" parent="1">
          <mxGeometry x="820" y="260" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell id="e1" style="endArrow=block;" edge="1" parent="1" source="login" target="auth">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=block;" edge="1" parent="1" source="home" target="habits">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=block;" edge="1" parent="1" source="home" target="checkin">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="endArrow=block;" edge="1" parent="1" source="group" target="group_api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="endArrow=block;" edge="1" parent="1" source="stats" target="auth">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="endArrow=block;" edge="1" parent="1" source="backend" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>