{
  "name": "habit-tracker-backend",
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && node --watch src/server.js",
    "start": "node src/server.js",
    "db:migrate": "node scripts/prisma-with-env.mjs migrate dev",
    "db:migrate:deploy": "node scripts/prisma-with-env.mjs migrate deploy",
    "db:push": "node scripts/prisma-with-env.mjs db push",
    "db:seed": "node scripts/prisma-with-env.mjs db seed",
    "db:studio": "node scripts/prisma-with-env.mjs studio"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "nodemailer": "^8.0.5",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  }
}
