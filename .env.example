# Database
POSTGRES_DB=habittracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@db:5432/habittracker

# Auth
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# App
NODE_ENV=development
FRONTEND_URL=http://localhost

# Rate limiting (GET /auth/me ne compte pas dans AUTH — voir rateLimiter.js)
API_RATE_WINDOW_MS=900000
API_RATE_MAX=100
AUTH_RATE_MAX=30
# Derrière Nginx / Traefik : IP client pour le rate limit (1 = premier proxy)
# TRUST_PROXY=1
