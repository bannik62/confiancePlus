# Database
POSTGRES_DB=habittracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@db:5432/habittracker

# Auth
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# Seed Prisma (`npm run db:seed` depuis la racine avec Docker, ou `backend`: `npm run db:seed:local` si la DB est joignable)
# Compte admin démo : username AdminDemo · admin@demo.dev — mot de passe = ADMIN_SEED_PASSWORD ou défaut demo1234
# ADMIN_SEED_PASSWORD=demo1234

# App
NODE_ENV=development
FRONTEND_URL=http://localhost
# Inscription publique POST /auth/register : false pour fermer (check-code / activate asso restent actifs)
REGISTER_OPEN=true

# Rate limiting (GET /auth/me ne compte pas dans AUTH — voir rateLimiter.js)
API_RATE_WINDOW_MS=900000
API_RATE_MAX=100
AUTH_RATE_MAX=30
# Derrière Nginx / Traefik : IP client pour le rate limit (1 = premier proxy)
# TRUST_PROXY=1

# Web Push (notifications) — générer avec : npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@example.com

# Rappels RDV par e-mail (Gmail — même variables que zerok-billing sur le VPS)
# GMAIL_USER=ton-adresse@gmail.com
# GMAIL_APP_PASSWORD=mot_de_passe_application_16_caracteres
# Heure locale (0–23) pour l’e-mail « la veille » du RDV (défaut 18)
# APPOINTMENT_REMINDER_DAY_BEFORE_HOUR=18

# Production (VPS) : voir .env.prod.example + docker-compose.prod.yml
